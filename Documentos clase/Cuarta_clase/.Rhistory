library(haven)
library(siebanxicor)
library(tidyverse)
library(here)
tokenbanxico = "722cbe96cb081225e74de97e4d37a564cf9d4d72d44701b772a3dfc8a8055383"
setToken(tokenbanxico)
tc <- getSeriesData("SF60653",
"2010-01-01",
Sys.Date()
)
tc <- getSerieDataFrame(tc, "SF60653")
